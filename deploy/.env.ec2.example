# Copie para a raiz do projeto na EC2: cp deploy/.env.ec2.example .env
#
# IMPORTANTE: DD_SITE deve ser o site do SEU tenant (canto inferior esquerdo no Datadog).
# Exemplo Datadog US5: us5.datadoghq.com  (NÃO use datadoghq.com se sua org é US5)

DD_API_KEY=
DD_SITE=us5.datadoghq.com
DD_ENV=aws-ec2
DD_VERSION=1.0.0

DD_LLMOBS_ENABLED=1
# Nome exibido no LLM Observability (igual ao wizard ou o que preferir)
DD_LLMOBS_ML_APP=llmobs_retail_multiagent_running_over_multiservices
# Com Datadog Agent no docker-compose.prod.yml, use false
DD_LLMOBS_AGENTLESS_ENABLED=false

USE_MOCK_LLM=true
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
