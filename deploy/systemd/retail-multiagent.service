[Unit]
Description=Retail LLM Multi-Agent (Docker Compose)
Documentation=https://github.com/DataDog/dd-trace-py
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=ec2-user
Group=docker
WorkingDirectory=/home/ec2-user/LLM_MultiAgent
EnvironmentFile=-/home/ec2-user/LLM_MultiAgent/.env
ExecStart=/usr/bin/docker compose -f docker-compose.prod.yml up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f docker-compose.prod.yml down
ExecReload=/usr/bin/docker compose -f docker-compose.prod.yml up -d --build
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
