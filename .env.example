# Datadog (obrigatório para enviar traces)
DD_API_KEY=
# Site do tenant: datadoghq.com | datadoghq.eu | us3.datadoghq.com | us5.datadoghq.com | ...
DD_SITE=us5.datadoghq.com
DD_ENV=dev
DD_VERSION=1.0.0

# LLM Observability — mesmo ml_app nos dois serviços = trace LLM unificado
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=llmobs_retail_multiagent_running_over_multiservices
# auto = agentless se DD_API_KEY existir; senão usa Datadog Agent em :8126
# AWS EC2 (docker-compose.prod.yml): use false — ver deploy/.env.ec2.example
DD_LLMOBS_AGENTLESS_ENABLED=auto

# APM multi-service (um DD_SERVICE por processo)
# retail-gateway  → porta 8001
# retail-processor → porta 8002

# OpenAI (opcional — sem chave usa mock LLM)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_MOCK_LLM=auto

PROCESSOR_URL=http://localhost:8002
